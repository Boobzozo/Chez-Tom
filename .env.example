# Copier ce fichier en `.env` et remplir les valeurs.

# Port du serveur (3000 par défaut)
PORT=3000

# URL publique du site (sans slash final).
# Utilisée pour le retour OAuth Google Calendar, ex. https://chez-tom.fr
APP_URL=""

# Intégration Google Calendar (facultative) — identifiants OAuth
# à créer sur https://console.cloud.google.com (API Calendar activée).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email de confirmation via Resend (facultatif — https://resend.com).
# Si vide, aucun email n'est envoyé par le site (n8n peut s'en charger).
RESEND_API_KEY=""
